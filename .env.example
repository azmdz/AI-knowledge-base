# ローカル開発
DATABASE_URL="file:./dev.db"

# Vercel + Turso デプロイ時は以下を使用
# DATABASE_URL="libsql://your-db-name.turso.io"
# TURSO_AUTH_TOKEN="eyJ..."

# AI provider: mock | openai | anthropic
# mock      : APIキーなしで動作（簡易整形・キーワード検索）
# openai    : OpenAI GPT-4o を使用（推奨）
# anthropic : Claude API を使用
AI_PROVIDER=mock

OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# 使用するClaudeモデル（省略時は claude-opus-4-8）
# ANTHROPIC_MODEL=claude-opus-4-8
