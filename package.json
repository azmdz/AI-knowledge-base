    "@mui/icons-material": "^9.1.1",
    "@mui/material": "^9.1.2",
    "@prisma/adapter-libsql": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@tailwindcss/typography": "^0.5.20",
    "@tiptap/extension-placeholder": "^3.27.1",
    "@tiptap/react": "^3.27.1",
    "@tiptap/starter-kit": "^3.27.1",
    "diff": "^9.0.0",
    "next": "^16.2.9",
